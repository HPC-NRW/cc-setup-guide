[Unit]
Description=ClusterCockpit In-Memory Timeseries Database (cc-metric-store)
Documentation=https://github.com/ClusterCockpit/cc-metric-store
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=clustercockpit
Group=clustercockpit
Restart=on-failure
RestartSec=30
TimeoutStopSec=100
LimitNOFILE=infinity
ExecStart=__INSTALL_DIR__/cc-metric-store/cc-metric-store --config __INSTALL_DIR__/cc-metric-store/config.json

[Install]
WantedBy=multi-user.target
